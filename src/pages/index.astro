---
import HomepageIntroSlide from "../components/homepage/HomepageIntroSlide.astro";
import HomepageProjectSlide from "../components/homepage/HomepageProjectSlide.astro";
import HeroSlide from "../components/homepage/HeroSlide.astro";
import FooterSlide from "../components/homepage/FooterSlide.astro";
import type {
  PresentationSlide,
  Project,
} from "../components/homepage/types";
import Layout from "../layouts/Layout.astro";
import { getHomepage } from "../sanity/lib/sanity-utils";

const homepage = await getHomepage();

const galleries = (homepage?.galleries ?? []).slice(0, 2);
const slides = galleries.flatMap((gallery) => gallery.slides);
---

<Layout>
  <main class="h-dvh overflow-y-auto overscroll-y-contain snap-y snap-mandatory bg-stone-100 text-neutral-950">
    <HeroSlide />
    {slides.length ? (
      slides.map((slide) =>
        slide._type === "homepageGalleryPresentationSlide" ? (
          <HomepageIntroSlide slide={slide as PresentationSlide} />
        ) : (
          <HomepageProjectSlide slide={slide as Project} />
        ),
      )
    ) : (
      <section class="flex min-h-dvh snap-start items-center justify-center bg-stone-100 px-6">
        <div class="max-w-md text-center">
          <p class="text-pretty text-base text-neutral-600">
            Ajoutez deux galleries dans Sanity pour remplir la homepage.
          </p>
        </div>
      </section>
    )}
    <FooterSlide />
  </main>
</Layout>

<script>
  const updateProjectCard = (card) => {
    const state = Number(card.dataset.state || "0");
    const galleryStates = Array.from(card.querySelectorAll("[data-gallery-state]"));
    const progress = card.querySelector("[data-gallery-progress]");
    const mediaCounter = card.querySelector("[data-media-counter]");

    galleryStates.forEach((panel) => {
      panel.dataset.visible = panel.dataset.galleryState === String(state) ? "true" : "false";
    });

    if (mediaCounter) {
      const mediaTotal = galleryStates.length + 1;
      const mediaIndex = Math.min(Math.max(state, 1), mediaTotal);
      mediaCounter.textContent = `${mediaIndex}/${mediaTotal}`;
    }

    if (progress) {
      const galleryIndex = Math.max(state - 1, 1);
      const galleryTotal = Math.max(galleryStates.length, 1);
      progress.textContent =
        state >= 2 ? `Gallery ${Math.min(galleryIndex, galleryTotal)}/${galleryTotal}` : "Click to reveal";
    }
  };

  const advanceProjectCard = (card) => {
    const currentState = Number(card.dataset.state || "0");
    const maxState = Number(card.dataset.maxState || "1");
    const nextState = currentState >= maxState ? 0 : currentState + 1;
    card.dataset.state = String(nextState);
    updateProjectCard(card);
  };

  const retreatProjectCard = (card) => {
    const currentState = Number(card.dataset.state || "0");
    const maxState = Number(card.dataset.maxState || "1");
    const nextState = currentState <= 0 ? maxState : currentState - 1;
    card.dataset.state = String(nextState);
    updateProjectCard(card);
  };

  document.querySelectorAll("[data-project-card]").forEach((card) => {
    updateProjectCard(card);

    card.addEventListener("click", (event) => {
      const bounds = card.getBoundingClientRect();
      const clickedOnRightHalf = event.clientX >= bounds.left + bounds.width / 2;

      if (clickedOnRightHalf) {
        advanceProjectCard(card);
        return;
      }

      retreatProjectCard(card);
    });

    card.addEventListener("keydown", (event) => {
      if (event.key === "ArrowRight") {
        event.preventDefault();
        advanceProjectCard(card);
        return;
      }

      if (event.key === "ArrowLeft") {
        event.preventDefault();
        retreatProjectCard(card);
        return;
      }

      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        advanceProjectCard(card);
      }
    });
  });
</script>
