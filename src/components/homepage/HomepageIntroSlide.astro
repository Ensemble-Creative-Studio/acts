---
import type { PresentationSlide } from "./types";

type Props = {
  slide: PresentationSlide;
};

const { slide } = Astro.props;
const introBackground = slide.color || "#262626";
---

<section class="slide-shell snap-start">
  <article
    class="slide-panel flex items-center justify-center px-6 py-12"
    style={`background-color: ${introBackground};`}
  >
    <div class="mx-auto max-w-5xl text-center">
      <h2 class="text-balance text-5xl font-semibold uppercase leading-none text-white md:text-7xl font-avant-garde">
        {slide.title || "Featured Work"}
      </h2>
      {slide.subtitle ? (
        <p class="mx-auto mt-6 max-w-2xl text-pretty text-xl font-medium uppercase text-white sm:text-base font-avant-garde">
          {slide.subtitle}
        </p>
      ) : null}
    </div>
  </article>
</section>
