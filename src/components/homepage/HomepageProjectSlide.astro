---
import { Image } from "astro:assets";
import arrowCursorLeftRaw from "../../assets/arrow-cursor-left.svg?raw";
import arrowCursorRightRaw from "../../assets/arrow-cursor-right.svg?raw";
import MuxVideoPlayer from "../MuxVideoPlayer";
import type { Project, ProjectCredit, ImageAsset, ProjectGalleryItem } from "./types";

type Props = {
  slide: Project;
};

const { slide } = Astro.props;

const formatCredit = (credit: ProjectCredit) =>
  [credit.jobs, credit.name].filter(Boolean).join(" ");

const getImageData = (image?: ImageAsset) => ({
  src: image?.asset?.url,
  width: image?.asset?.metadata?.dimensions?.width ?? 1600,
  height: image?.asset?.metadata?.dimensions?.height ?? 2000,
});

const getMuxPosterUrl = (playbackId?: string) =>
  playbackId ? `https://image.mux.com/${playbackId}/thumbnail.webp?time=0` : undefined;

const mainImage =
  slide.mainMedia?.mediaType === "image" ? getImageData(slide.mainMedia.image) : undefined;
const mainPlaybackId =
  slide.mainMedia?.mediaType === "video"
    ? slide.mainMedia.video?.asset?.playbackId
    : undefined;
const mainPosterUrl =
  slide.mainMedia?.mediaType === "video"
    ? getMuxPosterUrl(slide.mainMedia.video?.asset?.playbackId)
    : undefined;
const galleryItems = slide.gallery ?? [];
type GalleryStateEntry = {
  item: ProjectGalleryItem;
  itemIndex: number;
  desktopState: number;
  mobileStates: number[];
};

let desktopStateCursor = 2;
let mobileStateCursor = 2;

const galleryStateEntries: GalleryStateEntry[] = galleryItems.map((item, itemIndex) => {
  const isSplitItem =
    item._type === "projectGallerySplitLeft" || item._type === "projectGallerySplitRight";
  const entry = {
    item,
    itemIndex,
    desktopState: desktopStateCursor,
    mobileStates: isSplitItem ? [mobileStateCursor, mobileStateCursor + 1] : [mobileStateCursor],
  };

  desktopStateCursor += 1;
  mobileStateCursor += isSplitItem ? 2 : 1;

  return entry;
});

const desktopMaxState = desktopStateCursor - 1;
const mobileMaxState = mobileStateCursor - 1;
const projectBackground = slide.color || "#f5e9e6";
const mediaCount = desktopMaxState;
const initialMediaCount = `1/${mediaCount}`;
const arrowCursorLeftUrl = `data:image/svg+xml,${encodeURIComponent(arrowCursorLeftRaw)}`;
const arrowCursorRightUrl = `data:image/svg+xml,${encodeURIComponent(arrowCursorRightRaw)}`;
const isMainMediaVideo = slide.mainMedia?.mediaType === "video";
const projectTitleColor = slide.titleColor || "#000000";
---

<section class="slide-shell snap-start" data-page-background={projectBackground}>
  <article
    class="slide-panel group overflow-hidden"
    data-project-card
    data-state="0"
    data-max-state-desktop={desktopMaxState}
    data-max-state-mobile={mobileMaxState}
    tabindex="0"
    role="button"
    aria-label={`Reveal ${slide.name || "project"} gallery`}
    style={`background-color: ${projectBackground}; --project-cursor-left: url("${arrowCursorLeftUrl}"); --project-cursor-right: url("${arrowCursorRightUrl}");`}
  >
    <div class="relative flex h-full items-center justify-center">
    <div class="absolute inset-0 z-30 hidden md:block" aria-hidden="true">
      <div class="project-card-cursor-zone project-card-cursor-zone--left absolute inset-y-0 left-0 w-1/2"></div>
      <div class="project-card-cursor-zone project-card-cursor-zone--right absolute inset-y-0 right-0 w-1/2"></div>
    </div>
    <div
      class="relative flex w-full max-w-7xl items-center justify-center px-5 py-8 opacity-100 transition-opacity duration-300 ease-out data-[visible='false']:opacity-0 sm:px-8 md:px-12"
      data-main-media
      data-visible="true"
    >
      <div
        class={`relative flex items-center justify-center ${
          slide.mainMedia?.mediaType === "video"
            ? "z-40 max-h-[72dvh] w-auto max-w-[min(82vw,72rem)] overflow-hidden"
            : "max-h-[72dvh] min-w-72 md:min-w-200"
        }`}
      >
        {slide.mainMedia?.mediaType === "video" && mainPlaybackId ? (
          <MuxVideoPlayer
            client:load
            className="mux-clean h-full w-auto max-w-full object-contain"
            playbackId={mainPlaybackId}
            poster={mainPosterUrl}
            title={slide.name || "Project video"}
            fit="contain"
          />
        ) : mainImage?.src ? (
          <Image
            src={mainImage.src}
            alt={slide.mainMedia?.image?.alt || slide.name || "Project image"}
            class="h-auto max-h-[72dvh] w-auto max-w-full object-contain"
            width={mainImage.width}
            height={mainImage.height}
            loading="lazy"
          />
        ) : (
          <div class="flex size-full items-center justify-center px-6 text-center text-sm uppercase text-stone-600">
            Image manquante
          </div>
        )}
      </div>
    </div>

    <div class="pointer-events-none absolute inset-0">
      {galleryStateEntries.map(({ item, itemIndex, desktopState, mobileStates }) => {
        const desktopStateValue = String(desktopState);
        const firstMobileStateValue = String(mobileStates[0]);
        const secondMobileStateValue = String(mobileStates[1] ?? mobileStates[0]);

        if (item._type === "projectGalleryFullImageRow") {
          const image = getImageData(item.image);

          return (
            <div
              class="absolute inset-0 flex items-center justify-center px-5 py-8 opacity-0 transition-opacity duration-300 ease-out data-[visible='true']:opacity-100 sm:px-8 md:px-12"
              data-gallery-panel
              data-gallery-item-index={String(itemIndex)}
              data-gallery-desktop-state={desktopStateValue}
              data-gallery-mobile-state={firstMobileStateValue}
              data-visible="false"
            >
              <div class="flex h-full w-full items-center justify-center">
                <div class="relative flex max-h-[72dvh] w-full max-w-[min(84vw,78rem)] items-center justify-center overflow-hidden">
                  {image.src ? (
                    <Image
                      src={image.src}
                      alt={item.image?.alt || slide.name || "Gallery image"}
                      class="max-h-[72dvh] w-auto max-w-full object-contain"
                      width={image.width}
                      height={image.height}
                      loading="lazy"
                    />
                  ) : (
                    <div class="flex size-full items-center justify-center bg-stone-300 px-6 text-center text-sm uppercase text-stone-600">
                      Image manquante
                    </div>
                  )}
                </div>
              </div>
            </div>
          );
        }

        if (item._type === "projectGalleryFullVideoRow") {
          const playbackId = item.video?.asset?.playbackId;
          const posterUrl = getMuxPosterUrl(playbackId);

          return (
            <div
              class="absolute inset-0 flex items-center justify-center px-5 py-8 opacity-0 transition-opacity duration-300 ease-out data-[visible='true']:opacity-100 sm:px-8 md:px-12"
              data-gallery-panel
              data-gallery-item-index={String(itemIndex)}
              data-gallery-desktop-state={desktopStateValue}
              data-gallery-mobile-state={firstMobileStateValue}
              data-visible="false"
            >
              <div class="relative z-40 flex max-h-[72dvh] w-full max-w-[min(84vw,78rem)] items-center justify-center">
                {playbackId ? (
                  <MuxVideoPlayer
                    client:load
                    className="mux-clean max-h-[72dvh] w-auto max-w-full object-contain"
                    playbackId={playbackId}
                    poster={posterUrl}
                    title={slide.name || "Gallery video"}
                    fit="contain"
                  />
                ) : (
                  <div class="flex size-full items-center justify-center px-6 text-center text-sm uppercase text-stone-300">
                    Video indisponible
                  </div>
                )}
              </div>
            </div>
          );
        }

        const leftMedia = item.leftMedia;
        const rightMedia = item.rightMedia;
        const leftIsLarge = item._type === "projectGallerySplitLeft";
        const leftImage =
          leftMedia?.mediaType === "image" ? getImageData(leftMedia.image) : undefined;
        const rightImage =
          rightMedia?.mediaType === "image" ? getImageData(rightMedia.image) : undefined;
        const leftPlaybackId =
          leftMedia?.mediaType === "video"
            ? leftMedia.video?.asset?.playbackId
            : undefined;
        const rightPlaybackId =
          rightMedia?.mediaType === "video"
            ? rightMedia.video?.asset?.playbackId
            : undefined;
        const leftPosterUrl =
          leftMedia?.mediaType === "video"
            ? getMuxPosterUrl(leftPlaybackId)
            : undefined;
        const rightPosterUrl =
          rightMedia?.mediaType === "video"
            ? getMuxPosterUrl(rightPlaybackId)
            : undefined;

        return (
          <>
            <div
              class="absolute inset-0 hidden opacity-0 transition-opacity duration-300 ease-out data-[visible='true']:opacity-100 md:block"
              data-gallery-panel
              data-gallery-item-index={String(itemIndex)}
              data-gallery-desktop-state={desktopStateValue}
              data-visible="false"
            >
              <div
                class="flex h-full w-full flex-col md:flex-row"
                style={`background-color: ${projectBackground};`}
              >
                <div
                  class={`relative h-[50dvh] w-full overflow-hidden md:h-full ${
                    leftIsLarge ? "md:basis-[60%]" : "md:basis-[40%]"
                  }`}
                >
                  {leftIsLarge ? (
                    <div class="relative z-40 flex h-full w-full items-center justify-start">
                      {leftMedia?.mediaType === "video" && leftPlaybackId ? (
                        <MuxVideoPlayer
                          client:load
                          className="mux-clean h-full w-auto object-contain object-left"
                          playbackId={leftPlaybackId}
                          poster={leftPosterUrl}
                          title={slide.name || "Gallery video"}
                          fit="contain"
                        />
                      ) : leftImage?.src ? (
                        <Image
                          src={leftImage.src}
                          alt={leftMedia?.image?.alt || slide.name || "Gallery image"}
                          class="h-full w-auto object-contain object-left"
                          width={leftImage.width}
                          height={leftImage.height}
                          loading="lazy"
                        />
                      ) : (
                        <div class="flex size-full items-center justify-center bg-stone-300 px-6 text-center text-sm uppercase text-stone-600">
                          {leftMedia?.mediaType === "video" ? "Video" : "Image manquante"}
                        </div>
                      )}
                    </div>
                  ) : (
                    <div
                      class="flex h-full w-full items-center justify-start"
                      style={`background-color: ${projectBackground};`}
                    >
                      <div class="relative z-40 h-full w-auto overflow-hidden md:mr-auto md:h-[70dvh] md:max-h-[70dvh]">
                        {leftMedia?.mediaType === "video" && leftPlaybackId ? (
                          <MuxVideoPlayer
                            client:load
                            className="mux-clean h-full w-auto object-contain object-left"
                            playbackId={leftPlaybackId}
                            poster={leftPosterUrl}
                            title={slide.name || "Gallery video"}
                            fit="contain"
                          />
                        ) : leftImage?.src ? (
                          <Image
                            src={leftImage.src}
                            alt={leftMedia?.image?.alt || slide.name || "Gallery image"}
                            class="h-full w-auto object-contain object-left"
                            width={leftImage.width}
                            height={leftImage.height}
                            loading="lazy"
                          />
                        ) : (
                          <div class="flex size-full items-center justify-center bg-stone-300 px-6 text-center text-sm uppercase text-stone-600">
                            {leftMedia?.mediaType === "video" ? "Video" : "Image manquante"}
                          </div>
                        )}
                      </div>
                    </div>
                  )}
                </div>

                <div
                  class={`flex w-full items-center px-0 py-0 md:h-full md:px-0 md:py-0 ${
                    leftIsLarge
                      ? "md:basis-[40%] md:justify-end"
                      : "md:basis-[60%] md:justify-end"
                  }`}
                  style={`background-color: ${projectBackground};`}
                >
                  <div
                    class={`relative overflow-hidden ${
                      leftIsLarge
                        ? "z-40 h-[50dvh] w-full md:ml-auto md:h-[70dvh] md:max-h-[70dvh] md:w-auto"
                        : "z-40 h-[50dvh] w-full md:h-full md:w-auto"
                    }`}
                  >
                    {leftIsLarge ? (
                      rightMedia?.mediaType === "video" && rightPlaybackId ? (
                        <MuxVideoPlayer
                          client:load
                          className="mux-clean h-full w-auto object-contain object-right"
                          playbackId={rightPlaybackId}
                          poster={rightPosterUrl}
                          title={slide.name || "Gallery video"}
                          fit="contain"
                        />
                      ) : rightImage?.src ? (
                        <Image
                          src={rightImage.src}
                          alt={rightMedia?.image?.alt || slide.name || "Gallery image"}
                          class="h-full w-auto object-contain object-right"
                          width={rightImage.width}
                          height={rightImage.height}
                          loading="lazy"
                        />
                      ) : (
                        <div class="flex size-full items-center justify-center px-6 text-center text-sm uppercase text-stone-600">
                          {rightMedia?.mediaType === "video" ? "Video" : "Image manquante"}
                        </div>
                      )
                    ) : rightMedia?.mediaType === "video" && rightPlaybackId ? (
                      <MuxVideoPlayer
                        client:load
                        className="mux-clean h-full w-auto object-contain object-right"
                        playbackId={rightPlaybackId}
                        poster={rightPosterUrl}
                        title={slide.name || "Gallery video"}
                        fit="contain"
                      />
                    ) : rightImage?.src ? (
                      <Image
                        src={rightImage.src}
                        alt={rightMedia?.image?.alt || slide.name || "Gallery image"}
                        class="h-full w-auto object-contain object-right"
                        width={rightImage.width}
                        height={rightImage.height}
                        loading="lazy"
                      />
                    ) : (
                      <div class="flex size-full items-center justify-center px-6 text-center text-sm uppercase text-stone-600">
                        {rightMedia?.mediaType === "video" ? "Video" : "Image manquante"}
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>

            <div
              class="absolute inset-0 opacity-0 transition-opacity duration-300 ease-out data-[visible='true']:opacity-100 md:hidden"
              data-gallery-panel
              data-gallery-item-index={String(itemIndex)}
              data-gallery-mobile-state={firstMobileStateValue}
              data-visible="false"
            >
              <div
                class="flex h-full w-full items-center justify-center px-5 py-8"
                style={`background-color: ${projectBackground};`}
              >
                <div class="relative z-40 flex h-full w-full items-center justify-center overflow-hidden">
                  {leftMedia?.mediaType === "video" && leftPlaybackId ? (
                    <MuxVideoPlayer
                      client:load
                      className="mux-clean h-full w-auto max-w-full object-contain"
                      playbackId={leftPlaybackId}
                      poster={leftPosterUrl}
                      title={slide.name || "Gallery video"}
                      fit="contain"
                    />
                  ) : leftImage?.src ? (
                    <Image
                      src={leftImage.src}
                      alt={leftMedia?.image?.alt || slide.name || "Gallery image"}
                      class="h-full w-auto max-w-full object-contain"
                      width={leftImage.width}
                      height={leftImage.height}
                      loading="lazy"
                    />
                  ) : (
                    <div class="flex size-full items-center justify-center bg-stone-300 px-6 text-center text-sm uppercase text-stone-600">
                      {leftMedia?.mediaType === "video" ? "Video" : "Image manquante"}
                    </div>
                  )}
                </div>
              </div>
            </div>

            <div
              class="absolute inset-0 opacity-0 transition-opacity duration-300 ease-out data-[visible='true']:opacity-100 md:hidden"
              data-gallery-panel
              data-gallery-item-index={String(itemIndex)}
              data-gallery-mobile-state={secondMobileStateValue}
              data-visible="false"
            >
              <div
                class="flex h-full w-full items-center justify-center px-5 py-8"
              style={`background-color: ${projectBackground};`}
            >
                <div class="relative z-40 flex h-full w-full items-center justify-center overflow-hidden">
                  {rightMedia?.mediaType === "video" && rightPlaybackId ? (
                    <MuxVideoPlayer
                      client:load
                      className="mux-clean h-full w-auto max-w-full object-contain"
                      playbackId={rightPlaybackId}
                      poster={rightPosterUrl}
                      title={slide.name || "Gallery video"}
                      fit="contain"
                    />
                  ) : rightImage?.src ? (
                    <Image
                      src={rightImage.src}
                      alt={rightMedia?.image?.alt || slide.name || "Gallery image"}
                      class="h-full w-auto max-w-full object-contain"
                      width={rightImage.width}
                      height={rightImage.height}
                      loading="lazy"
                    />
                  ) : (
                    <div class="flex size-full items-center justify-center bg-stone-300 px-6 text-center text-sm uppercase text-stone-600">
                      {rightMedia?.mediaType === "video" ? "Video" : "Image manquante"}
                    </div>
                  )}
                </div>
              </div>
            </div>
          </>
        );
      })}
    </div>

    <div
      class="pointer-events-none absolute inset-0 z-50 flex items-center justify-center px-4 opacity-100 transition-opacity duration-300 ease-out data-[visible='false']:opacity-0"
      data-project-title
      data-visible="true"
      style={isMainMediaVideo ? "mix-blend-mode: difference;" : undefined}
    >
      <h2
        class="absolute text-balance font-avant-garde text-center text-5xl md:text-7xl font-semibold uppercase leading-none"
        style={`color: ${projectTitleColor};`}
      >
        {slide.name || "Untitled Project"}
      </h2>

    </div>

    <div
      class="pointer-events-none absolute inset-x-5 bottom-5 z-50 flex items-center justify-between gap-x-6 uppercase font-avant-garde font-medium text-black sm:inset-x-6 sm:bottom-6"
    >
      <div class="flex min-w-0 flex-col md:flex-row md:flex-wrap md:items-baseline md:gap-x-3 md:gap-y-0">
        <p class="text-base font-bold md:font-medium md:text-2xl">{slide.name}</p>
          <div class="flex min-w-0 flex-col md:flex-row md:flex-wrap md:items-baseline md:gap-x-3 md:gap-y-0">
            {slide.credits?.map((credit) => (
              <p class="flex items-baseline gap-x-1 md:gap-x-2">
                <span class="text-xs md:text-sm">{credit.jobs}</span>
                <span class="text-xs font-bold md:font-medium md:text-xl">{credit.name}</span>
              </p>
            ))}
          </div>
      </div>

      <p class="hidden md:block shrink-0 text-3xl tabular-nums sm:text-3xl" data-media-counter>{initialMediaCount}</p>
    </div>
    </div>
  </article>
</section>
