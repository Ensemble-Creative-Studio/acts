---
import LogoLong from "../../assets/logo_long.svg";
---

<section class="slide-shell snap-start">
  <div class="slide-panel relative block bg-[#e9e1da]">
    <p class="max-w-136 px-6 py-6 text-pretty text-base font-medium leading-tight text-neutral-950 sm:px-8 sm:py-8 sm:text-lg md:px-10 md:py-10 md:text-xl">
      Born in the circulations of the contemporary world, we believe in the force of the collective and the beauty of contrasts. Our practice is an alliance of sensibilities and resonances that responds to the growing need for 360° creative ecosystems.
    </p>
    <div class="absolute bottom-0 left-0 w-screen">
      <LogoLong class="h-full w-full object-contain" />
    </div>
  </div>
</section>
