---
import Logo from "../assets/logo.svg";

interface Props {
  hiddenUntilHeroEnd?: boolean;
}

const { hiddenUntilHeroEnd = false } = Astro.props;
---

<header
  class:list={[
    "pointer-events-none fixed inset-x-0 top-0 z-50 transition-opacity duration-700 ease-out",
    hiddenUntilHeroEnd && "header-hidden-until-hero opacity-0",
  ]}
  data-hidden-until-hero-end={hiddenUntilHeroEnd ? "true" : "false"}
>
  <div class="flex w-full items-center justify-between px-5 py-5 uppercase sm:px-6 sm:py-6 md:px-8">
    <a href="/" class="pointer-events-auto"> 
      <Logo class="h-8 md:h-10 w-auto" />
    </a>
    <div class="flex items-center gap-4 pointer-events-auto">
      <a href="/" class="font-avant-garde md:text-xl text-lg font-bold leading-none tracking-[-1px] text-black hover:cursor-pointer">
        Projects
      </a>
    <a href="/events" class="font-avant-garde md:text-xl text-lg font-bold leading-none tracking-[-1px] text-black hover:cursor-pointer">
      Events
    </a>
    <a href="/info" class="font-avant-garde md:text-xl text-lg font-bold leading-none tracking-[-1px] text-black hover:cursor-pointer">
      Info
    </a>
  </div>
  </div>
</header>

<style>
  .header-hidden-until-hero {
    visibility: hidden;
  }

  :global(html[data-hero-seen="true"]) .header-hidden-until-hero,
  .header-hidden-until-hero[data-header-visible="true"] {
    visibility: visible;
    opacity: 1;
  }
</style>
